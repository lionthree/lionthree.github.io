---
// Footer.astro
---

<footer id="contact" class="w-full flex flex-col">
    <!-- Big Contact Callout -->
    <a
        href="mailto:miguel.asen.maya@gmail.com"
        class="glow-container w-full p-6 md:p-12 hairline-b flex flex-col md:flex-row justify-between items-start md:items-end gap-12 hover:bg-text hover:text-black transition-colors duration-700 cursor-pointer group"
    >
        <div class="flex flex-col gap-4">
            <span
                data-i18n="contact.label"
                class="text-[10px] uppercase tracking-[0.2em] italic opacity-60 group-hover:opacity-100"
                >Got a project?</span
            >
            <h2
                data-i18n="contact.title"
                class="text-6xl md:text-8xl font-black tracking-tighter uppercase leading-[0.85]"
            >
                Let's Talk
            </h2>
        </div>
        <div
            class="flex items-center gap-4 text-xs font-medium uppercase tracking-widest italic opacity-80 group-hover:opacity-100"
        >
            <span
                class="w-8 h-[1px] bg-text group-hover:bg-black transition-colors"
            ></span>
            <span data-i18n="contact.email">Send an Email</span>
        </div>
    </a>

    <!-- Socials & Meta -->
    <div
        class="w-full grid grid-cols-1 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-border text-[10px] uppercase font-bold tracking-[0.15em] italic"
    >
        <a
            href="#"
            class="glow-container p-6 md:p-8 hover:bg-text hover:text-black transition-colors flex justify-between"
        >
            <span>Instagram</span>
            <span>↗</span>
        </a>
        <a
            href="#"
            class="glow-container p-6 md:p-8 hover:bg-text hover:text-black transition-colors flex justify-between"
        >
            <span>ArtStation</span>
            <span>↗</span>
        </a>
        <a
            href="#"
            class="glow-container p-6 md:p-8 hover:bg-text hover:text-black transition-colors flex justify-between"
        >
            <span>LinkedIn</span>
            <span>↗</span>
        </a>
        <a
            href="#"
            class="glow-container p-6 md:p-8 hover:bg-text hover:text-black transition-colors flex justify-between"
        >
            <span>Twitter / X</span>
            <span>↗</span>
        </a>
    </div>

    <div
        class="w-full p-6 md:px-12 md:py-4 flex justify-between items-center text-[9px] uppercase tracking-[0.3em] opacity-40 hairline-t"
    >
        <div class="flex items-center gap-4">
            <img
                src="/logo_black.png"
                alt="lionlionlion mark"
                class="w-8 md:w-15 h-8 md:h-15 object-contain dark:invert opacity-80"
            />
            <span>© {new Date().getFullYear()} lionlionlion</span>
        </div>
        <span>Zaragoza, ES</span>
    </div>
</footer>
