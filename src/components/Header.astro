---
// Header.astro
---
<header id="main-header" class="sticky z-50 flex items-center justify-between px-4 sm:px-6 md:px-12 border-border bg-bg/95">
    <a href="/" class="text-xl sm:text-2xl md:text-3xl font-black tracking-tighter uppercase leading-none hover:opacity-70 transition-opacity relative z-50">
        lionlionlion<span class="text-[10px] sm:text-xs md:text-sm align-top font-bold">®</span>
    </a>
    
    <nav class="hidden md:flex items-center gap-16 text-[10px] uppercase tracking-[0.15em] font-medium italic">
        <a href="#about" data-i18n="nav.about" class="hover:opacity-50 transition-opacity duration-300">About</a>
        <a href="#works" data-i18n="nav.works" class="hover:opacity-50 transition-opacity duration-300">Works</a>
        <a href="#software" data-i18n="nav.software" class="hover:opacity-50 transition-opacity duration-300">Software</a>
        <a href="#contact" data-i18n="nav.contact" class="hover:opacity-50 transition-opacity duration-300">Contact</a>
    </nav>
    
    <div class="flex items-center gap-4 md:gap-6 relative z-50">
        <button id="theme-toggle" class="w-4 h-4 shrink-0 rounded-full border border-border bg-text hover:opacity-50 transition-opacity" title="Toggle Theme"></button>
        <button id="lang-toggle" class="text-[10px] font-bold uppercase tracking-widest hover:opacity-50 transition-opacity">ES</button>
        <button id="menu-toggle" class="md:hidden text-[10px] uppercase font-medium italic tracking-widest hover:opacity-50 transition-opacity text-right">
            <span id="menu-text" data-i18n="nav.menu">Menu</span>
        </button>
    </div>
</header>
