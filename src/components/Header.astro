---
// Header.astro
---
<header id="main-header" class="sticky z-50 flex items-center justify-between px-4 sm:px-6 md:px-12 border-border bg-bg/95 backdrop-blur-md transition-colors duration-500">
    <div class="flex-1 flex justify-start">
        <a href="/" id="brand-logo" class="text-xl sm:text-2xl md:text-3xl font-black tracking-tighter uppercase leading-none hover:text-[#ffcb00] transition-all duration-500 origin-left relative z-50">
            lionlionlion<span class="text-[10px] sm:text-xs md:text-sm align-top font-bold">®</span>
        </a>
    </div>
    
    <nav class="hidden md:flex items-center gap-10 text-xs sm:text-sm uppercase tracking-tighter font-black">
        <a href="#about" data-i18n="nav.about" class="hover:opacity-50 transition-opacity duration-300 mt-[2px]">About</a>
        <a href="#works" data-i18n="nav.works" class="hover:opacity-50 transition-opacity duration-300 mt-[2px]">Works</a>
        <a href="#software" data-i18n="nav.software" class="hover:opacity-50 transition-opacity duration-300 mt-[2px]">Software</a>
        <a href="#contact" data-i18n="nav.contact" class="hover:opacity-50 transition-opacity duration-300 mt-[2px]">Contact</a>
    </nav>
    
    <div class="flex-1 flex justify-end items-center gap-4 md:gap-6 relative z-50">
        <button id="theme-toggle" class="relative w-6 h-6 shrink-0 flex items-center justify-center rounded-full hover:opacity-50 transition-all duration-500 overflow-hidden" title="Toggle Theme">
            <!-- Sun Icon (Visible in Light Mode) -->
            <svg id="sun-icon" class="absolute w-4 h-4 text-text transition-all duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"></circle>
                <line x1="12" y1="1" x2="12" y2="3"></line>
                <line x1="12" y1="21" x2="12" y2="23"></line>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                <line x1="1" y1="12" x2="3" y2="12"></line>
                <line x1="21" y1="12" x2="23" y2="12"></line>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <!-- Moon Icon (Visible in Dark Mode) -->
            <svg id="moon-icon" class="absolute w-4 h-4 text-text transition-all duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
        </button>
        <button id="lang-toggle" class="text-xs sm:text-sm font-black uppercase tracking-tighter px-3 h-[26px] md:px-4 md:h-[28px] flex items-center justify-center rounded-full border-2 border-text hover:bg-text hover:text-bg transition-colors pt-[2px]">ES</button>
        <button id="menu-toggle" class="md:hidden text-xs uppercase font-black tracking-tighter hover:opacity-50 transition-opacity text-right mt-[2px]">
            <span id="menu-text" data-i18n="nav.menu">Menu</span>
        </button>
    </div>
</header>
