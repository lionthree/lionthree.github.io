---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro Portfolio - Swissfolio Style">
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo_black.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Inter Font (Swiss Style) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

		<!-- Lenis Smooth Scroll -->
		<script src="https://unpkg.com/lenis@1.1.2/dist/lenis.min.js"></script>

		<!-- Inline script for FOUC prevention -->
		<script is:inline>
			const theme = localStorage.getItem('theme');
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			}
		</script>
	</head>
	<body class="bg-bg text-text font-sans antialiased overflow-x-hidden transition-colors duration-300">
		<!-- Custom Brutalist Cross Cursor -->
		<div id="brutalist-cursor" class="pointer-events-none fixed top-0 left-0 z-[9999] p-1 mix-blend-difference text-white transition-opacity duration-300 ease-out opacity-0 flex items-center justify-center">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 ease-out will-change-transform">
				<line x1="12" y1="2" x2="12" y2="22"></line>
				<line x1="2" y1="12" x2="22" y2="12"></line>
			</svg>
		</div>

		<!-- Main grid container: centered, max-width, with left/right hairlines -->
		<main class="max-w-[1536px] mx-auto border-x-[0.5px] border-border min-h-screen flex flex-col pt-12 transition-colors duration-300">
			<slot />
		</main>

		<!-- Project Modal Overlay -->
		<div id="project-modal" class="fixed inset-0 z-[100] opacity-0 pointer-events-none transition-opacity duration-500 overflow-hidden">
			<!-- Close Button (Fixed to the wrapper) -->
			<button id="close-modal" class="absolute top-6 right-6 text-[10px] md:text-xs uppercase font-black tracking-widest hover:bg-text hover:text-bg transition-colors duration-300 z-50 px-5 py-2.5 rounded-full border border-text text-text group flex items-center justify-center gap-2 bg-bg/50 backdrop-blur-md">
				<span class="pt-[2px]">Close (ESC)</span> 
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="mb-[1px]">
					<line x1="18" y1="6" x2="6" y2="18"></line>
					<line x1="6" y1="6" x2="18" y2="18"></line>
				</svg>
			</button>

			<!-- Scrollable Content Layer -->
			<div data-lenis-prevent class="absolute inset-0 w-full h-full overflow-y-auto pt-24 px-4 md:px-12 pb-12 z-10 flex flex-col">
				<div class="max-w-6xl mx-auto w-full flex flex-col gap-6 opacity-0 translate-y-12 transition-all duration-700 ease-out" id="modal-content">
					<div class="flex flex-col gap-2">
						<p id="modal-tags" class="text-[10px] uppercase tracking-widest font-bold opacity-60">Tags</p>
						<h2 id="modal-title" class="text-5xl md:text-8xl font-black tracking-tighter uppercase leading-[0.85] text-text mb-4">Project Title</h2>
					</div>
					<div class="w-full h-[1px] bg-border mb-8"></div>
					<div id="modal-media" class="w-full flex justify-center mb-8 bg-text/5 rounded-2xl overflow-hidden aspect-video md:aspect-[21/9]">
						<!-- Media injected here -->
					</div>
					<div class="grid grid-cols-1 md:grid-cols-12 gap-12 w-full">
						<div class="md:col-span-8 flex flex-col gap-6 text-base md:text-lg font-medium tracking-tight leading-relaxed opacity-80" id="modal-description">
							<!-- Description injected here -->
						</div>
						<div class="md:col-span-4 flex flex-col gap-4 text-xs uppercase tracking-widest font-bold">
							<p class="opacity-50 border-b border-border pb-2">Client / Role</p>
							<p>Personal Project - 3D Artist</p>
							<p class="opacity-50 border-b border-border pb-2 mt-4">Year</p>
							<p id="modal-year">2024</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Back to Top Button -->
		<button id="back-to-top" class="fixed bottom-6 right-6 w-12 h-12 rounded-full border border-border bg-bg/90 backdrop-blur-md flex items-center justify-center hover:bg-text hover:text-bg transition-all duration-500 z-50 opacity-0 pointer-events-none translate-y-4 shadow-lg group">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="12" y1="19" x2="12" y2="5"></line>
				<polyline points="5 12 12 5 19 12"></polyline>
			</svg>
		</button>

		<!-- Mobile Menu Overlay -->
		<div id="mobile-menu" class="fixed inset-0 z-40 bg-bg flex flex-col items-center justify-center gap-8 text-4xl sm:text-5xl uppercase tracking-tighter font-black transition-colors duration-500 ease-out">
			<a href="#about" class="mobile-link hover:opacity-50 transition-opacity" data-i18n="nav.about">About</a>
			<a href="#works" class="mobile-link hover:opacity-50 transition-opacity" data-i18n="nav.works">Works</a>
			<a href="#software" class="mobile-link hover:opacity-50 transition-opacity" data-i18n="nav.software">Software</a>
			<a href="#contact" class="mobile-link hover:opacity-50 transition-opacity" data-i18n="nav.contact">Contact</a>
		</div>

		<!-- Client side logic -->
		<script>
			// Language dictionary
			const translations = {
				en: {
					"nav.about": "About",
					"nav.works": "Works",
					"nav.software": "Software",
					"nav.contact": "Contact",
					"nav.menu": "Menu",
					"nav.close": "Close",
					"hero.subtitle": "3D Artist &<br/> Visual Designer",
					"hero.location": "Based in<br/> Zaragoza, Spain",
					"hero.scroll": "[ SCROLL TO EXPLORE ]",
					"works.title": "Selected Works",
					"works.hover": "Hover to expand",
					"software.title": "Software<br/>& Tools",
					"software.subtitle": "The technical stack behind the works",
					"contact.label": "Got a project?",
					"contact.title": "Let's Talk",
					"contact.email": "Send an Email",
					"lang.switch": "ES"
				},
				es: {
					"nav.about": "Sobre Mí",
					"nav.works": "Trabajos",
					"nav.software": "Software",
					"nav.contact": "Contacto",
					"nav.menu": "Menú",
					"nav.close": "Cerrar",
					"hero.subtitle": "Artista 3D &<br/> Diseñador Visual",
					"hero.location": "Basado en<br/> Zaragoza, España",
					"hero.scroll": "[ HAZ SCROLL ]",
					"works.title": "Trabajos Seleccionados",
					"works.hover": "Pasa el ratón para expandir",
					"software.title": "Software<br/>& Herramientas",
					"software.subtitle": "El stack técnico detrás de las obras",
					"contact.label": "¿Tienes un proyecto?",
					"contact.title": "Hablemos",
					"contact.email": "Enviar un Email",
					"lang.switch": "EN"
				}
			};

			let currentLang = localStorage.getItem('lang') || 'en';

			function applyLanguage(lang) {
				const dict = translations[lang];
				document.querySelectorAll('[data-i18n]').forEach((el) => {
					const key = el.getAttribute('data-i18n');
					if (dict[key]) {
						el.innerHTML = dict[key];
					}
				});
				const btn = document.getElementById('lang-toggle');
				if (btn) btn.innerText = dict['lang.switch'];
			}

			// Initialize
			applyLanguage(currentLang);

			// Listen for toggle events
			document.addEventListener('DOMContentLoaded', () => {
				const themeToggle = document.getElementById('theme-toggle');
				const langToggle = document.getElementById('lang-toggle');

				if (themeToggle) {
					themeToggle.addEventListener('click', () => {
						document.documentElement.classList.toggle('dark');
						const isDark = document.documentElement.classList.contains('dark');
						localStorage.setItem('theme', isDark ? 'dark' : 'light');
					});
				}

				if (langToggle) {
					langToggle.addEventListener('click', () => {
						currentLang = currentLang === 'en' ? 'es' : 'en';
						localStorage.setItem('lang', currentLang);
						applyLanguage(currentLang);
						
						// Update menu button text if menu is open
						const mobileMenu = document.getElementById('mobile-menu');
						const menuText = document.getElementById('menu-text');
						if (mobileMenu && menuText && mobileMenu.classList.contains('is-active')) {
							menuText.innerText = translations[currentLang]['nav.close'];
						}
					});
				}

				// --- Mobile Menu Logic ---
				const menuToggle = document.getElementById('menu-toggle');
				const mobileMenu = document.getElementById('mobile-menu');
				const menuText = document.getElementById('menu-text');

				if (menuToggle && mobileMenu && menuText) {
					const toggleMenu = () => {
						const isOpen = mobileMenu.classList.contains('is-active');
						
						if (isOpen) {
							// Close
							mobileMenu.classList.remove('is-active');
							menuText.innerText = translations[currentLang]['nav.menu'];
							document.body.style.overflow = '';
						} else {
							// Open
							mobileMenu.classList.add('is-active');
							menuText.innerText = translations[currentLang]['nav.close'];
							document.body.style.overflow = 'hidden';
						}
					};

					menuToggle.addEventListener('click', toggleMenu);

					const mobileLinks = document.querySelectorAll('.mobile-link');
					mobileLinks.forEach(link => {
						link.addEventListener('click', () => {
							if (mobileMenu.classList.contains('is-active')) {
								toggleMenu();
							}
						});
					});
				}

				// --- Floating Capsule Header Logic ---
				const header = document.getElementById('main-header');
				const heroName = document.getElementById('hero-name');
				
				if (header) {
					window.addEventListener('scroll', () => {
						const scrollY = window.scrollY;

						if(heroName) {
							const maxScroll = window.innerHeight;
							const progress = Math.min(scrollY / maxScroll, 1);
							heroName.style.transform = `scale(${1 - (progress * 0.35)}) translateY(${scrollY * 0.4}px)`;
							heroName.style.opacity = `${1 - (progress * 1.6)}`;
						}

						if (scrollY > 40) {
							header.classList.add('capsule');
						} else {
							header.classList.remove('capsule');
						}
					}, { passive: true });
				}

				// --- Spotlight Glow Logic ---
				const glowContainers = document.querySelectorAll('.glow-container');
				glowContainers.forEach(container => {
					container.addEventListener('mousemove', (e) => {
						const rect = container.getBoundingClientRect();
						const x = e.clientX - rect.left;
						const y = e.clientY - rect.top;
						container.style.setProperty('--mouse-x', `${x}px`);
						container.style.setProperty('--mouse-y', `${y}px`);
					});
				});

				// --- Brutalist Cursor Logic ---
				const cursor = document.getElementById('brutalist-cursor');
				const cursorSvg = cursor?.querySelector('svg');
				let cursorX = window.innerWidth / 2;
				let cursorY = window.innerHeight / 2;
				let mouseX = cursorX;
				let mouseY = cursorY;

				if (cursor) {
					window.addEventListener('mousemove', (e) => {
						if (cursor.style.opacity !== '1') cursor.style.opacity = '1';
						mouseX = e.clientX;
						mouseY = e.clientY;
					});

					function animateCursor() {
						cursorX += (mouseX - cursorX) * 0.2;
						cursorY += (mouseY - cursorY) * 0.2;
						cursor.style.transform = `translate3d(${cursorX - 16}px, ${cursorY - 16}px, 0)`;
						requestAnimationFrame(animateCursor);
					}
					animateCursor();

					const interactives = document.querySelectorAll('a, button, [role="button"], .project-card');
					interactives.forEach(el => {
						el.addEventListener('mouseenter', () => {
							if(cursorSvg) cursorSvg.style.transform = 'rotate(45deg) scale(0.8)';
						});
						el.addEventListener('mouseleave', () => {
							if(cursorSvg) cursorSvg.style.transform = 'rotate(0deg) scale(1)';
						});
					});
				}

				// --- Project Modal Logic ---
				const modal = document.getElementById('project-modal');
				const closeModalBtn = document.getElementById('close-modal');
				const modalContent = document.getElementById('modal-content');
				const modalTitle = document.getElementById('modal-title');
				const modalTags = document.getElementById('modal-tags');
				const modalYear = document.getElementById('modal-year');
				const modalMedia = document.getElementById('modal-media');
				const modalDesc = document.getElementById('modal-description');
				const projectCards = document.querySelectorAll('.project-card');

				const openModal = (card) => {
					if(!modal) return;
					const title = card.getAttribute('data-title');
					const tags = card.getAttribute('data-tags');
					const year = card.getAttribute('data-year');
					
					if(modalTitle) modalTitle.innerHTML = title;
					if(modalTags) modalTags.innerHTML = tags;
					if(modalYear) modalYear.innerHTML = year;
					
					// Temporary placeholder media
					if(modalMedia) modalMedia.innerHTML = `<div class="w-full h-full bg-text/10 flex justify-center items-center text-xs font-black uppercase tracking-widest text-text opacity-50"><img src="/logo_black.png" class="opacity-20 h-48 w-48 object-contain" /></div>`;
					
					if(modalDesc) modalDesc.innerHTML = `<p>Detailed case study for <b>${title}</b>. This project involved extensive exploration of 3D forms, blending conceptual design with technical execution. The primary focus was creating a cohesive visual language.</p><p class="mt-4">Developed directly within our core software stack, leveraging procedural generation and meticulous hand-crafted detailing to achieve the final look.</p>`;

					modal.classList.remove('opacity-0', 'pointer-events-none');
					document.body.style.overflow = 'hidden';
					if (window.lenis) window.lenis.stop();

					setTimeout(() => {
						modalContent.classList.remove('opacity-0', 'translate-y-12');
					}, 50);
				};

				const closeModal = () => {
					if(!modal) return;
					modalContent.classList.add('opacity-0', 'translate-y-12');
					setTimeout(() => {
						modal.classList.add('opacity-0', 'pointer-events-none');
						document.body.style.overflow = '';
						if (window.lenis) window.lenis.start();
					}, 300);
				};

				projectCards.forEach(card => {
					card.addEventListener('click', () => openModal(card));
				});

				if(closeModalBtn) closeModalBtn.addEventListener('click', closeModal);
				
				document.addEventListener('keydown', (e) => {
					if(e.key === 'Escape' && modal && !modal.classList.contains('pointer-events-none')) {
						closeModal();
					}
				});

				// --- Back to Top Logic ---
				const btt = document.getElementById('back-to-top');
				if(btt) {
					window.addEventListener('scroll', () => {
						if(window.scrollY > 400) {
							btt.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
						} else {
							btt.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
						}
					}, { passive: true });
					
					btt.addEventListener('click', () => {
						window.scrollTo({ top: 0, behavior: 'smooth' });
					});
				}

				// --- Lenis Smooth Scroll Init ---
				if (typeof Lenis !== 'undefined') {
					const lenis = new Lenis({
						duration: 1.2,
						easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
						smooth: true,
					});
					window.lenis = lenis;

					function raf(time) {
						lenis.raf(time);
						requestAnimationFrame(raf);
					}
					requestAnimationFrame(raf);
				}
			});
		</script>
	</body>
</html>

<style is:global>
	:root {
		--font-fallback: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
	}
	body {
		font-family: 'Inter', var(--font-fallback);
	}
	/* Hairline utilities */
	.hairline-b { border-bottom: 0.5px solid var(--border); }
	.hairline-t { border-top: 0.5px solid var(--border); }
	.hairline-l { border-left: 0.5px solid var(--border); }
	.hairline-r { border-right: 0.5px solid var(--border); }
	
	* { cursor: none; } /* overridden below by pointer media query in global.css */

	#project-modal {
		background: radial-gradient(circle at 50% 40%, color-mix(in srgb, var(--bg) 100%, transparent) 20%, color-mix(in srgb, var(--bg) 40%, transparent) 100%);
		backdrop-filter: blur(12px);
	}
</style>
